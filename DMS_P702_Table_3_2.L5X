<![CDATA[[XIC(Reset_Bypass_Acc_HMI) ,XIC(HMI_Bad_Part_Ack) ,XIC(ACK_Message) ,XIO(HMI_Bypass_Message_Trigger) XIO(Bad_Part) XIO(Incorrect_Login) XIO(Login_Active) ]MOV(0,Info_Messages);]]>
