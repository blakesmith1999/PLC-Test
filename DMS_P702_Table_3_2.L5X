<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MID(MES.PARTS.COM1,1,15,IX_Model)[EQU(MES.PARTS.COM1.DATA[14],65) ,EQU(MES.PARTS.COM1.DATA[14],66) ]OTE(IXNeeded);]]>
