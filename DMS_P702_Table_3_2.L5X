</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[[XIC(IX_Camera.Output.Trigger) XIC(IXNeeded) ,XIC(IX_VisionManual.0) ]XIO(MainIX1_ResultPass)XIO(MainIX1_ResultFailed)OTL(TriggerMainIX_1);]]>
