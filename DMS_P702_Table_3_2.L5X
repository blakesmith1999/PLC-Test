<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(Local:1:I.Data.14)NOP();]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[XIC(Local:1:I.Data.15)NOP();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Map_Outputs" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(Lock_Part)OTE(Local:1:O.Data.0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Latch_Assembly)OTE(Local:1:O.Data.1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Retract_Lock_Part)OTE(Local:1:O.Data.2);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
