<Routine Name="ACCESS_CONTROL" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[MOV(500,ICP_A_UAC.USER_INFO_HOLD_TMR.PRE) ,MOV(180000,ICP_A_UAC.LOGOUT_TMR.PRE) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[[XIC(ICP_A_UAC.HMI_LOGOUT_PB) ,XIC(ICP_A_UAC.LOGOUT_TMR.DN) ,XIC(S:FS) ]OTE(ICP_A_UAC.RESET);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[NEQ(ICP_A_UAC.SCANNED_USER,ICP_A_UAC.LAST_USER)ONS(ICP_A_UAC.ONS.0)[XIO(ICP_A_UAC.LOGOUT_TMR.TT) OTE(ICP_A_UAC.NEW_SCAN_DETECTED) ,OTE(ICP_A_UAC.READER_ACTIVE) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(ICP_A_UAC.NEW_SCAN_DETECTED) ,XIC(ICP_A_UAC.USER_INFO_HOLD_TMR.TT) ][TON(ICP_A_UAC.USER_INFO_HOLD_TMR,?,?) ,XIC(ICP_A_UAC.USER_INFO_HOLD_TMR.DN) COP(ICP_A_UAC.CLEAR_USER,ICP_A_UAC.SCANNED_USER,1) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[NEQ(ICP_A_UAC.CURRENT_USER.LEVEL,0) ,XIC(ICP_A_UAC.LOGOUT_TMR.TT) ][TON(ICP_A_UAC.LOGOUT_TMR,?,?) ,MUL(ICP_A_UAC.LOGOUT_TMR.PRE,0.001,ICP_A_UAC.LOGOUT_TIMER_PRE_VALUE) ,MUL(ICP_A_UAC.LOGOUT_TMR.ACC,0.001,ICP_A_UAC.LOGOUT_TIMER_PRE_VALUE) ,MUL(ICP_A_UAC.LOGOUT_TIMER_PRE_VALUE,ICP_A_UAC.LOGOUT_TIMER_ACC_VALUE,ICP_A_UAC.LOGOUT_TIME_REMAINING) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[XIC(ICP_A_UAC.NEW_SCAN_DETECTED) ,XIC(ICP_A_UAC.RESET) ][COP(ICP_A_UAC.CLEAR_USER,ICP_A_UAC.CURRENT_USER,1) ,OTU(ICP_A_UAC.USER_FOUND) ,XIC(ICP_A_UAC.RESET) [COP(ICP_A_UAC.CLEAR_USER.BADGE_ID,ICP_A_UAC.LAST_USER,1) ,COP(ICP_A_UAC.CLEAR_USER.BADGE_ID,ICP_A_UAC.SCANNED_USER,1) ,MOV(0,ICP_A_UAC.CURRENT_USER.LEVEL) ] [OTE(ICP_A_UAC.USER_LOGOUT) ,RES(ICP_A_UAC.LOGOUT_TMR) ] ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[NEQ(ICP_A_UAC.SCANNED_USER,ICP_A_UAC.STORED_USER_CREDS[99].BADGE_ID)XIO(ICP_A_UAC.USER_SEARCH.DN)FSC(ICP_A_UAC.USER_SEARCH,?,?,ALL,ICP_A_UAC.SCANNED_USER=ICP_A_UAC.STORED_USER_CREDS[ICP_A_UAC.USER_SEARCH.POS].BADGE_ID);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(ICP_A_UAC.USER_SEARCH.FD)NEQ(ICP_A_UAC.SCANNED_USER,ICP_A_UAC.CLEAR_USER.BADGE_ID)[COP(ICP_A_UAC.STORED_USER_CREDS[ICP_A_UAC.USER_SEARCH.POS].BADGE_ID,ICP_A_UAC.CURRENT_USER.BADGE_ID,1) ,COP(ICP_A_UAC.STORED_USER_CREDS[ICP_A_UAC.USER_SEARCH.POS].USER_NAME,ICP_A_UAC.CURRENT_USER.USER_NAME,1) ,COP(ICP_A_UAC.STORED_USER_CREDS[ICP_A_UAC.USER_SEARCH.POS].DESIGNATION,ICP_A_UAC.CURRENT_USER.DESIGNATION,1) ,COP(ICP_A_UAC.STORED_USER_CREDS[ICP_A_UAC.USER_SEARCH.POS].LEVEL,ICP_A_UAC.CURRENT_USER.LEVEL,1) ,OTL(ICP_A_UAC.USER_FOUND) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(ICP_A_UAC.USER_SEARCH.FD)OTU(ICP_A_UAC.USER_SEARCH.IN);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIC(ICP_A_UAC.USER_SEARCH.DN)COP(ICP_A_UAC.SCANNED_USER,ICP_A_UAC.LAST_USER,1);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[[EQU(ICP_A_UAC.CURRENT_USER.LEVEL,0) MOV(0,ICP_A_UAC.MSTATE) ,EQU(ICP_A_UAC.CURRENT_USER.LEVEL,1) MOV(1,ICP_A_UAC.MSTATE) OTE(ICP_A_UAC.LEVEL_A) ,EQU(ICP_A_UAC.CURRENT_USER.LEVEL,2) MOV(2,ICP_A_UAC.MSTATE) OTE(ICP_A_UAC.LEVEL_B) ,EQU(ICP_A_UAC.CURRENT_USER.LEVEL,3) MOV(3,ICP_A_UAC.MSTATE) OTE(ICP_A_UAC.LEVEL_C) ,EQU(ICP_A_UAC.CURRENT_USER.LEVEL,4) MOV(4,ICP_A_UAC.MSTATE) OTE(ICP_A_UAC.LEVEL_D) ,EQU(ICP_A_UAC.CURRENT_USER.LEVEL,10) MOV(1,ICP_A_UAC.MSTATE) OTE(ICP_A_UAC.LEVEL_ADMIN) ,NEQ(ICP_A_UAC.MSTATE,0) OTE(ICP_A_UAC.MSTATE_VISIBILITY) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[XIC(ICP_A_UAC.USER_FOUND)ONS(ICP_A_UAC.ONS.21)MOV(60,ICP_A_UAC.USER_LOG_HISTORY_INDEX);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[LBL(USER_LOG_LOOP)GRT(ICP_A_UAC.USER_LOG_HISTORY_INDEX,0)[COP(ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX-1].BADGE_ID,ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX].BADGE_ID,1) COP(ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX-1].USER_NAME,ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX].USER_NAME,1) COP(ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX-1].DESIGNATION,ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX].DESIGNATION,1) ,COP(ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX-1].DATE,ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX].DATE,1) COP(ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX-1].TIME,ICP_A_UAC.USER_LOG_HISTORY[ICP_A_UAC.USER_LOG_HISTORY_INDEX].TIME,1) ]SUB(ICP_A_UAC.USER_LOG_HISTORY_INDEX,1,ICP_A_UAC.USER_LOG_HISTORY_INDEX)JMP(USER_LOG_LOOP);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Bypass" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Bypasses

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[[XIC(Bypass_Part_Present) ,XIC(Part_Present_Bypassed) ]XIO(Disable_Bypass_Part_Present)XIO(Part_Present_Bypass_Timer.DN)[OTE(Part_Present_Bypassed) ,TON(Part_Present_Bypass_Timer,?,?) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Lock_Part_HMI) ,XIC(Lock_Part_Bypassed) ]XIO(Disable_Bypass_Lock_Part)XIO(Lock_Part_Bypass_Timer.DN)[OTE(Lock_Part_Bypassed) ,TON(Lock_Part_Bypass_Timer,?,?) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Latch_Assembly_HMI) ,XIC(Latch_Assembly_Bypassed) ]XIO(Disable_Bypass_Latch_Assembly)XIO(Latch_Assembly_Bypass_Timer.DN)[OTE(Latch_Assembly_Bypassed) ,TON(Latch_Assembly_Bypass_Timer,?,?) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[AFI()[XIC(Bypass_Camera) ,XIC(Camera_Bypassed) ]XIO(Disable_Bypass_Camera)[OTE(Camera_Bypassed) ,TON(Camera_Bypass_Timer,?,?) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Bypass Timers Renew

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Reset_Bypass_Acc_HMI)[RES(Part_Present_Bypass_Timer) ,RES(Lock_Part_Bypass_Timer) ,RES(Latch_Assembly_Bypass_Timer) ,RES(Camera_Bypass_Timer) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Bypass_New" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Bypasses

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[[XIC(Bypass_Part_Present) XIC(Bypass_Timer.DN) ,XIC(Bypass_Indefinitely.0) ]OTE(Part_Present_Bypassed);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Lock_Part_HMI) XIC(Bypass_Timer.DN) ,XIC(Bypass_Indefinitely.1) ]OTE(Lock_Part_Bypassed);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Latch_Assembly_HMI) XIC(Bypass_Timer.DN) ,XIC(Bypass_Indefinitely.2) ]OTE(Latch_Assembly_Bypassed);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Camera) XIC(Bypass_Timer.DN) ,XIC(Bypass_Indefinitely.3) ]OTE(Camera_Bypassed);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[HMI passwords
Limit is 8 Characters for the passwords]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[EQU(Eng_Pass,Password_Input) OTL(Eng_Logged_In) ,EQU(Maint_Pass,Password_Input) OTL(Maint_Logged_In) ,EQU(Prod_Pass,Password_Input) OTL(Prod_Logged_In) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[XIC(Eng_Logged_In) ,XIC(Prod_Logged_In) ,XIC(Maint_Logged_In) ]TON(Logout_Timer,?,?);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[XIC(Logout_PB) ,XIC(Logout_Timer.DN) ][OTU(Eng_Logged_In) ,OTU(Maint_Logged_In) ,OTU(Prod_Logged_In) ,COP(Empty,Password_Input,2) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[LOGOUT TIMER LOGIC]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Value set from HMI then convert Seconds to Milliseconds]]>
</Comment>
<Text>
<![CDATA[MUL(Set_Logout_Timer,1000,Logout_Timer.PRE);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Converting timer from Milliseconds to Seconds]]>
</Comment>
<Text>
<![CDATA[DIV(Logout_Timer.ACC,1000,Time_In_Seconds);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Subtracting to display time left]]>
</Comment>
<Text>
<![CDATA[SUB(Set_Logout_Timer,Time_In_Seconds,Login_Time_Left);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[BYPASS TIMER LOGIC]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Part_Present) ,XIC(Bypass_Lock_Part_HMI) ,XIC(Bypass_Latch_Assembly_HMI) ,XIC(Bypass_Camera) ]XIO(Bypass_Until_End_Of_Shift)TON(Bypass_Timer,?,?);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Only when the timer is running will the HMI bypass timer be visible. Otherwise no need for it to pop up on the HMI]]>
</Comment>
<Text>
<![CDATA[LIM(1,Bypass_Timer.ACC,Bypass_Timer.PRE)OTE(Bypass_Timer_Visible);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Only when the timer is running will the HMI Logout timer be visible. Otherwise no need for it to pop up on the HMI]]>
</Comment>
<Text>
<![CDATA[LIM(1,Logout_Timer.ACC,Logout_Timer.PRE)OTE(Logout_Timer_Visible);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[[XIC(Bypass_Timer.DN) ,XIC(End_Of_Shift) ][OTU(Bypass_Part_Present) ,OTU(Bypass_Lock_Part_HMI) ,OTU(Bypass_Latch_Assembly_HMI) ,OTU(Bypass_Camera) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[Value set from HMI then convert Minutes to Milliseconds]]>
</Comment>
<Text>
<![CDATA[MUL(Set_Bypass_Timer,60000,Bypass_Timer.PRE);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Comment>
<![CDATA[Converting Minutes to Miliseconds
]]>
</Comment>
<Text>
<![CDATA[DIV(Bypass_Timer.ACC,60000,Time_In_Minutes);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[Subtracting to display time left]]>
</Comment>
<Text>
<![CDATA[SUB(Set_Bypass_Timer,Time_In_Minutes,Bypass_Time_Left);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Text>
<![CDATA[GSV(WallClockTime,?,LocalDateTime,System_Time[0]);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[EQU(System_Time[3],6)EQU(System_Time[4],0)[OTU(Bypass_Until_End_Of_Shift) ,OTE(End_Of_Shift) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Dalsa_Camera" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Check Vision Results vs. MES Part_Numbers]]>
</Comment>
<Text>
<![CDATA[XIC(Cycle_Start)XIC(Cycle_Start2)XIO(Dalsa_Vision_Camera)OTE(Vision_trigger);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(Cycle_Start)XIO(Cycle_Start2)OTU(Switch_1)OTU(Switch_3)OTU(Switch_4)OTU(Drive_Mode_Switch)COP(Empty_String,MES.Vision_Results.COM2,1)COP(Empty_String,MES.Vision_Results.COM3,1)COP(Empty_String,MES.Vision_Results.COM4,1)COP(Empty_String,MES.Vision_Results.COM5,1)COP(Empty_String,MES.Vision_Results.COM6,1)COP(Empty_String,MES.Vision_Results.COM7,1)COP(Empty_String,MES.Vision_Results.COM8,1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[MID(MES.PARTS.COM1,1,15,Finish_Panel_Level)MID(MES.PARTS.COM2,1,13,Drive_Mode_Level)MID(MES.PARTS.COM3,1,13,Plug_120V_Level)MID(MES.PARTS.COM4,1,13,Plug_12V_Level)MID(MES.PARTS.COM5,1,13,TBC_Level)MID(MES.PARTS.COM6,1,15,Coin_Holder_Level)MID(MES.PARTS.COM7,1,15,Smart_USB)MID(MES.PARTS.COM8,1,13,Circuit_Breaker)MID(MES.PARTS.COM9,1,13,USB_less_Console)MID(MES.PARTS.COM11,1,15,Delete_Plug);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(inspection_delay)TON(inspection_delay_timer,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[[EQU(Finish_Panel_Level,B_Level_Panel_String) ,EQU(Finish_Panel_Level,D_level_Panel_String) ] EQU(MES.Vision_Results.COM9,Extended_Panel_Vision_Result) EQU(Delete_Plug,Empty_String) ,NEQ(Finish_Panel_Level,Empty_String) NEQ(Finish_Panel_Level,B_Level_Panel_String) NEQ(Finish_Panel_Level,D_level_Panel_String) NEQ(MES.Vision_Results.COM9,Extended_Panel_Vision_Result) ,NEQ(Delete_Plug,Empty_String) EQU(MES.Vision_Results.COM11,Extended_Panel_Vision_Result) NEQ(MES.Vision_Results.COM9,Extended_Panel_Vision_Result) ]OTL(Extended_Panel_Switches);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[NEQ(TBC_Level,Empty_String) EQU(TBC_Level,MES.Vision_Results.COM5) ,NEQ(Coin_Holder_Level,Empty_String) EQU(Coin_Holder_Level,MES.Vision_Results.COM6) ]ONS(Oneshot[21])[OTL(Switch_1) ,CTU(Switch_1_good,?,?) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[NEQ(Plug_12V_Level,Empty_String) EQU(Plug_12V_Level,MES.Vision_Results.COM4) NEQ(Circuit_Breaker,String_A) ,NEQ(Circuit_Breaker,Empty_String) EQU(Circuit_Breaker,MES.Vision_Results.COM8) ]ONS(Oneshot[22])[OTL(Switch_3) ,CTU(Switch_3_good,?,?) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[NEQ(Smart_USB,Empty_String) EQU(Smart_USB,MES.Vision_Results.COM7) ,NEQ(Plug_120V_Level,Empty_String) [EQU(Plug_120V_Level,MES.Vision_Results.COM3) ,EQU(Plug_120V_Level,D_level_120V_switch) EQU(MES.Vision_Results.COM3,D_level_120V_switch) ,EQU(Plug_120V_Level,B_level_120V_switch) EQU(MES.Vision_Results.COM3,D_level_120V_switch) ] ]ONS(Oneshot[23])[OTL(Switch_4) ,CTU(Switch_4_good,?,?) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[[NEQ(Drive_Mode_Level,Empty_String) EQU(Drive_Mode_Level,MES.Vision_Results.COM2) ONS(Oneshot[24]) ,XIC(debug_JP) ]OTL(Drive_Mode_Switch);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(TEST_BM) NEQ(Drive_Mode_Level,Empty_String) EQU(Drive_Mode_Level,MES.Vision_Results.COM2) ,XIC(TEST_BM) XIC(Drive_Mode_Switch) XIC(Switch_1) XIC(Switch_3) XIC(Switch_4) ]ONS(Oneshot[20])OTL(Dalsa_Vision_Camera);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIC(Dalsa_Vision_Camera)RTO(vision_reset,?,?)XIC(vision_reset.DN)OTU(Dalsa_Vision_Camera)OTU(Extended_Panel_Switches)OTU(Drive_Mode_Switch)OTU(Switch_4)OTU(Switch_1)OTU(Switch_3)RES(vision_reset)COP(Empty_String,Finish_Panel_Level,1)COP(Empty_String,Drive_Mode_Level,1)COP(Empty_String,Plug_120V_Level,1)COP(Empty_String,Circuit_Breaker,1)COP(Empty_String,Plug_12V_Level,1)COP(Empty_String,TBC_Level,1)COP(Empty_String,Coin_Holder_Level,1)COP(Empty_String,Smart_USB,1)COP(Empty_String,USB_less_Console,1)COP(Empty_String,Delete_Plug,1)OTU(inspection_delay);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[EQU(MES.PARTS.COM8,none_string)COP(Empty_String,Circuit_Breaker,1);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Dalsa Camera Montior Bits

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Dalsa_Camera:I.Data[5].0)TON(Heartbeat_Monitor_On,?,?);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIO(Dalsa_Camera:I.Data[5].0)TON(Heartbeat_Monitor_Off,?,?);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(Dalsa_Camera:I.Data[6].0)OTE(Dalsa_Program_Stopped);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[XIO(Dalsa_Camera:I.Data[7].0)OTE(Dalsa_Program_Switching_Disabled);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Requested Program and Echo'd Program must be the same for permission for trigger

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[8],Dalsa_Camera:O.Data[1])OTE(Permission_For_Program_Execution);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Camera Inputs

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[9],1)OTE(Overall_Result_Pass);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[9],3)OTE(Overall_Result_Fail);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[10],3)OTE(Short_Rod_Find_Fail);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[11],3)OTE(Long_Rod_Find_Fail);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[EQU(Dalsa_Camera:I.Data[12],3)OTE(Distance_Rods_Fail);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Camera Outputs

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[[XIC(Trigger_Camera) ,XIC(Manual_Mode_Active) XIC(Trigger_Camera_HMI) ]OTE(Dalsa_Camera:O.Data[2].0);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Text>
<![CDATA[[[XIC(Reset_Camera_PLC) ,XIC(Manual_Mode_Active) XIC(Reset_Camera_HMI) ,XIC(Reset_Cycle) ] ,XIC(TMR[16].TT) ][OTE(Dalsa_Camera:O.Data[3].0) ,TON(TMR[16],?,?) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Faults" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[EQU(Major_System_Fault,0)EQU(Camera_Fault,0)OTE(No_Faults_Active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Major System Faults

*********************************************************************************
]]>
</Comment>
<Text>
<![CDATA[[XIO(Emergency_Relay_Okay) ,XIC(Major_System_Fault.0) ]XIO(Fault_Reset)OTE(Major_System_Fault.0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Major System Faults

*********************************************************************************
]]>
</Comment>
<Text>
<![CDATA[[XIO(Main_Air_On) ,XIC(Major_System_Fault.1) ]XIO(Fault_Reset)OTE(Major_System_Fault.1);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Camera Faults

*********************************************************************************
]]>
</Comment>
<Text>
<![CDATA[[[XIC(Heartbeat_Monitor_Off.DN) ,XIC(Heartbeat_Monitor_On.DN) ] ,XIC(Camera_Fault.0) ]XIO(Fault_Reset)XIC(try)OTE(Camera_Fault.0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
