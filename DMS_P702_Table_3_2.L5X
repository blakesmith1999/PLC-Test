<Routine Name="IX_LH" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Job Change Request
]]>
</Comment>
<Text>
<![CDATA[[XIC(IX_Camera.Input.In_Run) XIC(IX_Camera.Input.Ready) XIC(Z_BSTest.3) ,XIC(IX_Camera.Output.Job_Change_Request) XIO(IX_Camera.Input.Program_Switching_Response) ]OTE(IX_Camera.Output.Job_Change_Request);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[EQU(IX_Camera.Input.Active_Job,IX_Camera.Output.Set_Job)XIC(IX_Camera.Input.Ready)XIC(IX_Camera.Input.In_Run)OTE(IX_Camera.Good);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Clear Buffer]]>
</Comment>
<Text>
<![CDATA[[AFI() XIC(IX_Camera.Pre_Clear_Buffer) ,XIC(IX_Camera.Post_Clear_Buffer) ]XIC(IX_Camera.Input.Ready)OTE(IX_Camera.Output.Clear_Buffer);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Move Camera Program into Camera Program]]>
</Comment>
<Text>
<![CDATA[MOV(0,IX_Camera.Output.Set_Job);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[----------PROGRAM BEGINS----------]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[XIC(IX_Camera.Check) [AFI() ONS(IX_Camera.ONS.0) ,XIC(IX_Camera.Input.OPTO) ONS(IX_Camera.ONS.3) ] XIO(IX_Camera.Bypassed) XIO(IX_Camera.Pass) ,XIC(IX_Camera.Input.Manual_Mode) XIC(IX_Camera.HMI.Cam_Test_PB) ONS(IX_Camera.ONS.1) ]MOV(Sequence_Step[_05_ClearBuffer],IX_Camera.Sequence);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Clear Buffer before Camera is triggered]]>
</Comment>
<Text>
<![CDATA[EQU(IX_Camera.Sequence,Sequence_Step[_05_ClearBuffer])[XIC(IX_Camera.Input.Ready) OTE(IX_Camera.Pre_Clear_Buffer) ,MOV(Sequence_Step[_10_Trigger],IX_Camera.Sequence) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Trigger Camera and move to next step once result is available

tigger response?]]>
</Comment>
<Text>
<![CDATA[[XIC(Cycle_Start) ,XIC(Cycle_Start2) ]OTE(IX_Camera.Output.Trigger);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Fixes the issue of check passing immediately if camera was triggered manually and the pic remained in the buffer. The Pre_Clear_Buffer did not clear it before the whole check passed in the main program.]]>
</Comment>
<Text>
<![CDATA[XIC(IX_Camera.Check)[XIC(IX_Camera.Output.Trigger) ,XIC(IX_Camera.First_Trigger) ]OTE(IX_Camera.First_Trigger);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIO(IX_Camera.Check)TON(IX_Camera.Result_Delay,?,?);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[EQU(Sequencer,60)OTE(IX_Camera.Post_Clear_Buffer);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[[XIC(IX_Camera.First_Trigger) ,LIM(10,Sequencer,45) XIC(IX_Camera.Display_Results) ]OTE(IX_Camera.Display_Results);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Holds the result of each tool in a separate variable, allowing Display_Results in HMI_Cam to determine how long results are held for.]]>
</Comment>
<Text>
<![CDATA[XIC(IX_Camera.Display_Results)[XIC(IX_Camera.Input.Pass) ,XIC(IX_Camera.Pass) ,XIC(IX_Camera.Bypassed) ]OTE(IX_Camera.Pass);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Clears the buffer again for best practice, and sends sequence back to step 0.]]>
</Comment>
<Text>
<![CDATA[EQU(IX_Camera.Sequence,Sequence_Step[_15_Results])CLR(IX_Camera.Sequence);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Set Sequence Steps]]>
</Comment>
<Text>
<![CDATA[[MOV(0,_05_ClearBuffer) ,MOV(1,_10_Trigger) ,MOV(2,_15_Results) ,MOV(3,_20_ClearBuffer2_Complete) ][MOV(5,Sequence_Step[_05_ClearBuffer]) ,MOV(10,Sequence_Step[_10_Trigger]) ,MOV(15,Sequence_Step[_15_Results]) ,MOV(20,Sequence_Step[_20_ClearBuffer2_Complete]) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[XIC(Bypass_IV2)ONS(Oneshot[29])OTE(Bypass_Pulse);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[XIC(Bypass_Pulse)XIC(IV2_Bypassed)OTU(IV2.Bypassed);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[XIC(Bypass_Pulse)XIO(IV2_Bypassed)OTL(IV2.Bypassed);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[XIC(IV2.Bypassed)OTE(IV2_Bypassed);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
