</Routine>
<Routine Name="MES_Steps" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[EQU(Sequencer,0)OTU(MES.START)OTU(MES.CAMERA)OTU(MES.PLCCOMP)OTU(MES.TORQUECOMPLETE)OTU(MES.COMPLETE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[EQU(Sequencer,50)OTL(MES.START);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[EQU(Sequencer,60)OTL(MES.CAMERA);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[EQU(Sequencer,70)OTL(MES.PLCCOMP);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[MID(MES.PARTS.COM1,2,15,PART_TYPE)[CMP(PART_TYPE=A.Part1) OTE(OPTION.1) ,CMP(PART_TYPE=A.Part2) OTE(OPTION.2) ,CMP(PART_TYPE=A.Part3) OTE(OPTION.3) ,CMP(PART_TYPE=A.Part4) OTE(OPTION.4) ,CMP(PART_TYPE=A.Part5) OTE(OPTION.5) ,CMP(PART_TYPE=A.Part6) OTE(OPTION.6) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[XIC(MES_Mode) [XIC(OPTION.1) ,XIC(OPTION.3) ] ,XIC(RS_Debug.1) ]OTE(Part_Style_1);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[[XIC(MES_Mode) [XIC(OPTION.2) ,XIC(OPTION.6) ] ,XIC(RS_Debug.0) ]OTE(Part_Style_2);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[GRT(Sequencer,30)[XIC(OPTION.3) ,XIC(OPTION.6) ]OTE(Job_5Screw_Selection);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[GRT(Sequencer,30)[XIC(OPTION.2) ,XIC(OPTION.1) ]OTE(Job_7Screw_Selection);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(MES_Mode)XIC(OPTION.3)OTE(Style_C);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIC(MES_Mode)XIC(OPTION.4)OTE(Style_D);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[XIC(MES_Mode)XIC(OPTION.5)OTE(Style_E);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[XIC(MES_Mode)XIC(OPTION.6)OTE(Style_F);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(Local:1:I.Data.5)OTE(MES_4WaySwitchPresent);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Mode_Selection" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIO(Auto_Mode_Active)XIO(Manual_Mode_Active)OTE(No_Mode_Active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Emergency_Relay_Okay)[XIC(Main_Air_On) ,][XIC(No_Mode_Active) XIC(Auto_Mode_Request_HMI) ,XIC(Auto_Mode_Active) ]XIO(No_Mode_Request_HMI)OTE(Auto_Mode_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Emergency_Relay_Okay)XIC(Main_Air_On)[XIC(No_Mode_Active) XIC(Manual_Mode_Request_HMI) ,XIC(Manual_Mode_Active) ]XIO(No_Mode_Request_HMI)OTE(Manual_Mode_Active);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(No_Mode_Request_PB)XIC(Login_Active)OTE(No_Mode_Request_HMI);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Solenoids" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[[XIC(Auto_Mode_Active) [XIC(Step_3_Active) XIC(Cycle_Start) XIC(Cycle_Start2) ,XIC(Lock_Part) ] XIO(Step_6_Active) ,XIC(Manual_Mode_Active) [XIC(Advance_Lock_Solenoid_HMI) ,XIC(Lock_Part) ] XIO(Retract_Lock_Solenoid_HMI) ]XIO(Reset_Cycle)OTE(Lock_Part);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[XIC(Auto_Mode_Active) [XIC(Step_3_Active) XIC(Cycle_Start) XIC(Cycle_Start2) ,XIC(Latch_Assembly) ] XIO(Step_6_Active) ,XIC(Manual_Mode_Active) [XIC(Advance_Latch_Solenoid_HMI) ,XIC(Latch_Assembly) ] XIO(Retract_Latch_Solenoid_HMI) ]XIO(Reset_Cycle)OTE(Latch_Assembly);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIO(Lock_Part)OTE(Retract_Lock_Part);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIO(Latch_Assembly)OTE(Retract_Latch_Assembly);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(Part_Present)TON(TMR[20],?,?);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_1" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[OTE(AK1);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(AK1)XIO(Part_Present)[OTE(Fault_Reset) ,OTE(Z_RNgael.0) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Cycle Start

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)[XIC(Main_Air_On) XIC(No_Faults_Active) ,][XIO(Lock_Part) ,XIC(Lock_Part_Bypassed) ][XIO(Latch_Assembly) ,XIC(Latch_Assembly_Bypassed) ][XIO(Part_Present) ,XIC(Part_Present_Bypassed) ]OTE(Step_1_Clear);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)[XIC(Step_1_Clear) ,XIC(Cycle_Ready) ]XIO(Reset_Cycle)OTE(Cycle_Ready);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_2" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Place Part

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)[XIO(Lock_Part) ,XIC(Lock_Part_Bypassed) ][XIO(Latch_Assembly) ,XIC(Latch_Assembly_Bypassed) ]OTE(Step_2_Clear);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Cycle_Ready)[XIC(Step_2_Clear) ,XIC(Step_2_Active) ]OTE(Step_2_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)[XIC(TMR[20].DN) ONS(Oneshot[7]) ,XIC(Part_Present_Bypassed) ,XIC(Step_2_Complete) ]XIO(Reset_Cycle)[OTE(Step_2_Complete) ,OTE(In_Cycle) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_3" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Step 3
Lock Part Solenoid 1 and 2

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)OTE(Step_3_Clear);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(In_Cycle)XIC(Step_3_Clear)OTE(Step_3_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Step_3_Active)[XIC(Step_2_Complete) [XIC(Lock_Part) XIC(Latch_Assembly) ,XIC(Lock_Part_Bypassed) ] ,XIC(Step_3_Complete) ]XIO(Reset_Cycle)OTE(Step_3_Complete);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_4" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Step 4
Operator Scan Parts, Compare with MES, Complete Assembly

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)OTE(Step_4_Clear);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(In_Cycle)XIC(Step_4_Clear)XIC(Step_3_Complete)[XIC(Lock_Part) XIC(Latch_Assembly) ,XIC(Lock_Part_Bypassed) ]OTE(Step_4_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)[XIC(Step_4_Active) ,XIC(Step_4_Complete) ][XIC(MES.COMPLETE) ,XIC(db_12v) ,]XIO(Reset_Cycle)[TON(TMR[14],?,?) ,XIC(TMR[14].DN) OTE(Step_4_Complete) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_5" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Step 5
Take Photos of Parts and compare with MES

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)OTE(Step_5_Clear);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(In_Cycle)XIC(Step_5_Clear)XIC(Step_4_Complete)OTE(Step_5_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Step_5_Active)[[TON(TMR[18],?,?) ,XIC(TMR[18].DN) TON(TMR[17],?,?) ] ,OTE(Debug_CK[1].0) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(Permission_For_Program_Execution)[XIC(Lock_Part) XIC(Latch_Assembly) ,XIC(Lock_Part_Bypassed) ]XIC(Cycle_Start)XIC(Cycle_Start2)[[XIC(TMR[17].TT) ,XIC(TMR[19].TT) XIO(Camera_Retries.DN) ] ,XIC(Debug_CK[1].0) ][OTE(Trigger_Camera) ,OTL(Debug_CK[1].3) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[-------------------------------------------------------------------------------------------------------------------------------------------------------

Debug Rung to Simulate Vision Process

-------------------------------------------------------------------------------------------------------------------------------------------------------]]>
</Comment>
<Text>
<![CDATA[XIC(Debug_CK[1].3)TON(Debug_CK_Timers[0],?,?);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(Debug_CK_Timers[0].DN)OTU(Debug_CK[1].3);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(Overall_Result_Fail)XIO(Camera_Retries.DN)XIO(TMR[21].TT)XIO(Step_5_Complete)OTE(Retry_Photo);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(Retry_Photo)[CTU(Camera_Retries,?,?) ,TON(TMR[19],?,?) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[[XIC(TMR[19].DN) ,XIC(TMR[21].TT) ]TON(TMR[21],?,?);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIC(Camera_Retries.DN) ,XIC(Debug_CK[1].2) ]XIO(Camera_Bypassed)OTE(Bad_Part);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Reset Camera Fails Manual

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Reset_Camera_Retries_HMI)RES(Camera_Retries);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[[XIC(Overall_Result_Pass) XIC(IV2.HMI.Tool_1.Input_Pass) ,XIC(Debug_CK[1].1) ]OTE(Good_Part);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Result Pass Counter Increments and Finish Step

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)[[XIC(Debug_CK_Timers[0].DN) ,XIC(debug_JP) ] XIC(Good_Part) ,XIC(Bad_Part) ,[XIC(Overall_Result_Fail) ,XIC(Dalsa_Program_Switching_Disabled) ] XIC(Camera_Bypassed) ,XIC(Step_5_Complete) ]XIC(Step_4_Complete)XIO(Reset_Cycle)OTE(Step_5_Complete);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[XIC(Good_Part)[CTU(Part_Count_Good_Partial,?,?) ,CTU(Part_Count_Good_Total,?,?) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(HMI_Bad_Part_Ack)[CTU(Part_Count_Bad_Partial,?,?) ,CTU(Part_Count_Bad_Total,?,?) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_6" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Release Part

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Emergency_Relay_Okay)OTE(Step_6_Clear);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Step_5_Complete)[XIC(Good_Part) ,XIC(Bad_Part) XIC(HMI_Bad_Part_Ack) ,XIC(Camera_Bypassed) ]OTE(Step_6_Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(Auto_Mode_Active)XIC(Step_6_Active)[XIO(Lock_Part) XIO(Latch_Assembly) ,XIC(Lock_Part_Bypassed) ]TON(TMR[26],?,?)XIC(TMR[26].DN)XIO(Reset_Cycle)OTE(Step_6_Complete);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Step_7" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[*********************************************************************************

Reset_Routine

*********************************************************************************]]>
</Comment>
<Text>
<![CDATA[[XIC(Cycle_Ready) XIC(Step_2_Complete) XIC(Step_3_Complete) XIC(Step_4_Complete) XIC(Step_5_Complete) XIC(Step_6_Complete) ,XIC(No_Mode_Active) ,XIC(Reset_Cycle_HMI) ][OTE(Reset_Cycle) ,OTU(Wait_Photo) ,RES(Camera_Retries) ,OTL(Debug.28) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="V01_VS" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[==================================================
VS CAMERA PROGRAM
==================================================
The goal of this program is for as much as possible of the inner workings of the camera to be confined to this routine.
The only tag that needs to be exposed to the main sequence is a pass bit. Otherwise, all enabling and retriggering are handled in this routine.]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[COP(VS:I,VS.I,1)COP(VS.O,VS:O,1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[==================================================
SEND DATA
==================================================]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[VS COM1]]>
</Comment>
<Text>
<![CDATA[[NEQ(MES.PARTS.COM5,none_string) EQU(MES.PARTS.COM6,none_string) COP(MES.PARTS.COM5,VS_Switch1,1) ,EQU(MES.PARTS.COM5,none_string) NEQ(MES.PARTS.COM6,none_string) COP(MES.PARTS.COM6,VS_Switch1,1) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[VS COM2]]>
</Comment>
<Text>
<![CDATA[NEQ(MES.PARTS.COM2,none_string)COP(MES.PARTS.COM2,VS_Switch2,1);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[VS COM3]]>
</Comment>
<Text>
<![CDATA[[NEQ(MES.PARTS.COM4,none_string) EQU(MES.PARTS.COM8,none_string) COP(MES.PARTS.COM4,VS_Switch3,1) ,EQU(MES.PARTS.COM4,none_string) NEQ(MES.PARTS.COM8,none_string) COP(MES.PARTS.COM8,VS_Switch3,1) ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[VS COM4]]>
</Comment>
<Text>
<![CDATA[[NEQ(MES.PARTS.COM3,none_string) EQU(MES.PARTS.COM7,none_string) COP(MES.PARTS.COM3,VS_Switch4,1) ,EQU(MES.PARTS.COM3,none_string) NEQ(MES.PARTS.COM7,none_string) COP(MES.PARTS.COM7,VS_Switch4,1) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Copy part numbers to array with predefined size that the VS input data reader is expecting (32 bytes)]]>
</Comment>
<Text>
<![CDATA[[COP(VS_Switch1.DATA[0],VS.O.InspectionParameters.InspectionParameter000[0],32) ,COP(VS_Switch2.DATA[0],VS.O.InspectionParameters.InspectionParameter001[0],32) ,COP(VS_Switch3.DATA[0],VS.O.InspectionParameters.InspectionParameter002[0],32) ,COP(VS_Switch4.DATA[0],VS.O.InspectionParameters.InspectionParameter003[0],32) ,COP(Serial_Number.DATA[0],VS.O.InspectionParameters.InspectionParameter004[0],32) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(Vision_trigger)ONS(VS.CTRL.ONS.0)OTE(VS.CTRL.Opto);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[==================================================
ENABLE THE CAMERA CHECK
==================================================]]>
</Comment>
<Text>
<![CDATA[OTE(VS.CTRL.Enable_Check);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[==================================================
TRIGGER REQUEST
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIC(VS.CTRL.Enable_Check) XIC(VS.CTRL.Opto) XIC(VS.I.Status.AssignableBitData20) XIC(VS.I.Status.AssignableBitData00) XIO(VS.CTRL.Pass) ,XIC(VS.O.Control.Trigger) ]XIO(VS.I.Status.AssignableBitData08)OTE(VS.O.Control.Trigger);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[==================================================
HOLDS RESULTS FOR AS LONG AS THEY ARE RELAVENT,
DISREGARD RESULTS OTHERWISE
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIC(VS.I.Status.AssignableBitData19) ,XIC(VS.CTRL.Hold_Results) ]XIC(VS.CTRL.Enable_Check)OTE(VS.CTRL.Hold_Results);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[==================================================
OVERALL PASS
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIC(VS.CTRL.Hold_Results) [XIC(VS.I.Status.Pass) ,XIC(VS.CTRL.Pass) ] ,XIC(VS.CTRL.Bypass) ]OTE(VS.CTRL.Pass);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[==================================================
ACKNOWLEDGE RESULT
==================================================]]>
</Comment>
<Text>
<![CDATA[XIC(VS.I.Status.AssignableBitData19)OTE(VS.O.Control.ResultAck);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[==================================================
TOOL 1 PASS
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIC(VS.CTRL.Hold_Results) [XIC(VS.I.Status.ToolJudge00) ,XIC(VS.CTRL.Pass_Tool[1]) ] ,XIC(VS.CTRL.Bypass_Tool[1]) ,XIC(VS.CTRL.Bypass) ]OTE(VS.CTRL.Pass_Tool[1]);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[==================================================
FAILS
==================================================]]>
</Comment>
<Text>
<![CDATA[XIC(VS.CTRL.Hold_Results)XIO(VS.CTRL.Bypass)[XIO(VS.CTRL.Pass) [XIO(VS.I.Status.Pass) ,XIC(VS.CTRL.Fail) ] OTE(VS.CTRL.Fail) ,XIO(VS.CTRL.Bypass_Tool[1]) XIO(VS.CTRL.Pass_Tool[1]) [XIO(VS.I.Status.ToolJudge00) ,XIC(VS.CTRL.Fail_Tool[1]) ] OTE(VS.CTRL.Fail_Tool[1]) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[==================================================
OVERALL RESULTS TO HMI
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIO(VS.CTRL.Pass) XIO(VS.CTRL.Fail) XIO(VS.CTRL.Bypass) MOV(0,VS.CTRL.HMI.Overall_Results) ,XIC(VS.CTRL.Pass) XIO(VS.CTRL.Fail) XIO(VS.CTRL.Bypass) MOV(1,VS.CTRL.HMI.Overall_Results) ,XIO(VS.CTRL.Pass) XIC(VS.CTRL.Fail) XIO(VS.CTRL.Bypass) MOV(2,VS.CTRL.HMI.Overall_Results) ,XIC(VS.CTRL.Bypass) MOV(3,VS.CTRL.HMI.Overall_Results) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[==================================================
TOOL 1 RESULTS TO HMI
==================================================]]>
</Comment>
<Text>
<![CDATA[[XIO(VS.CTRL.Pass_Tool[1]) XIO(VS.CTRL.Fail_Tool[1]) XIO(VS.CTRL.Bypass_Tool[1]) MOV(0,VS.CTRL.HMI.Results_Tool[1]) ,XIC(VS.CTRL.Pass_Tool[1]) XIO(VS.CTRL.Fail_Tool[1]) XIO(VS.CTRL.Bypass_Tool[1]) MOV(1,VS.CTRL.HMI.Results_Tool[1]) ,XIO(VS.CTRL.Pass_Tool[1]) XIC(VS.CTRL.Fail_Tool[1]) XIO(VS.CTRL.Bypass_Tool[1]) MOV(2,VS.CTRL.HMI.Results_Tool[1]) ,XIC(VS.CTRL.Bypass_Tool[1]) MOV(3,VS.CTRL.HMI.Results_Tool[1]) ];]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
