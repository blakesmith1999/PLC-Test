<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(TriggerMainIX_1)XIC(IX_Camera:O.Data[0].0)[XIC(IX_Camera:I.Data[20].0) ,XIC(IX_Camera:I.Data[20].1) ]OTL(MainIX1_Triggered);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIC(MainIX1_Triggered)XIO(IX_Camera:I.Data[20].1)OTL(MainIX1_FreshResult);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(IX_Camera.Output.Trigger)XIC(IX_VisionBypass)TON(IX_VisionBypassDwell,?,?);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[[XIC(MainIX1_FreshResult) ,XIC(IX_VisionBypassDwell.DN) ][[XIC(IX_Camera:I.Data[18].1) ,XIC(IX_VisionBypass) ] OTL(MainIX1_ResultPass) ,XIO(IX_Camera:I.Data[18].1) XIO(IX_VisionBypass) ONS(IXVision_OneShot.22) OTL(MainIX1_ResultFailed) ,OTU(TriggerMainIX_1) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(MainIX1_ResultFailed)XIO(MainIX1_FailCount.DN)[XIC(IX_EnableFail) CTU(MainIX1_FailCount,?,?) ,OTU(MainIX1_FreshResult) OTU(MainIX1_ResultFailed) OTU(MainIX1_Triggered) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(MainIX1_FailCount.DN)XIC(IX_EnableFail)OTL(MainIX1_ResultFail);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[XIO(TriggerMainIX_1)OTU(MainIX1_Triggered)OTU(MainIX1_FreshResult);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[[XIC(TriggerMainIX_1) XIO(MainIX1_Triggered) ONS(IXVision_OneShot.2) ,XIO(IX_Camera.Output.Trigger) XIO(IX_VisionManual.0) ]OTU(MainIX1_ResultPass)OTU(MainIX1_ResultFail);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[[XIO(IX_Camera.Output.Trigger) XIO(IX_VisionManual.0) ,XIC(IX_Camera.Output.Trigger) ONS(IXVision_OneShot.3) ]OTU(MainIX1_ResultFail)OTU(MainIX1_ResultPass)OTU(MainIX1_FreshResult)OTU(MainIX1_ResultFailed)OTU(MainIX1_Triggered);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[[XIC(MainIX1_ResultPass) ,[XIO(IXNeeded) ,XIC(IX_Bypass) ] ][OTE(IX_Camera.Input.Pass) ,OTE(MES_4WaySwitch_FullySeated) ];]]>
</Text>
</Rung>
