<![CDATA[XIC(Retract_Latch_Assembly)OTE(Local:1:O.Data.3);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIC(Local:1:O.Data.4)NOP();]]>
