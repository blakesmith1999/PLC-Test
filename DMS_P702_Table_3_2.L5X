</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Main IX 1 - Center Connector - 10.138.26.239
Control Panel - 10.138.27.4
Exp IX 1 -  Trailing Connectors (3 Small) 10.138.27.3
Control Panel - 10.138.27.5
Main IX 2 - Leading Connectors (2 Large) 10.138.26.238 
Control Panel - 10.138.27.7
Exp IX 2 - NC
Programmer Reserved - 10.138.27.6
Subnet 255.255.254.0]]>
